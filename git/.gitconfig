[color]
	ui = true
[commit]
	gpgsign = true
[core]
	editor = nvim
[filter "lfs"]
	clean = git-lfs clean -- %f
	process = git-lfs filter-process
	required = true
	smudge = git-lfs smudge -- %f
[github]
	user = peucastro
[gpg]
	format = ssh
[help]
	autocorrect = 1
[init]
	defaultBranch = main
[pull]
	rebase = false
[user]
	name = Pedro Castro
	email = falecompedroac@gmail.com
	signingKey = ~/.ssh/id_ed25519.pub
